# Sur EC2 : copier ce fichier en deploy/.env et renseigner les valeurs.
# Ne jamais committer deploy/.env

# Runtime (Clerk) — NEXT_PUBLIC_* embarqué dans l’image au build CI
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-05
SANITY_API_READ_TOKEN=

# Domaine public pointant vers l'IP publique ou l'Elastic IP de l'instance EC2.
TRUSTSHOP_DOMAIN=trustshop.example.com

# Email utilise par Let's Encrypt pour les notifications de certificat.
CERTBOT_EMAIL=admin@example.com

# Image surchargée par GitHub Actions au déploiement :
# WEB_IMAGE
