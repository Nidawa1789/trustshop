# Sur EC2 : copier ce fichier en deploy/.env et renseigner les valeurs.
# Ne jamais committer deploy/.env

# Mot de passe fort pour PostgreSQL (obligatoire en prod)
POSTGRES_PASSWORD=

POSTGRES_USER=trustshop
POSTGRES_DB=trustshop

# Runtime (Clerk) — NEXT_PUBLIC_* embarqué dans l’image au build CI
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Images surchargées par GitHub Actions au déploiement :
# WEB_IMAGE, API_IMAGE
